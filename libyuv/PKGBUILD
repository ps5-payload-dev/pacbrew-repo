pkgname=ps5-payload-libyuv
pkgver=r2828+ce488afb
pkgrel=1
pkgdesc="Library for YUV scaling"
arch=('any')
url="https://chromium.googlesource.com/libyuv/libyuv/"
license=(custom)
_commit=ce488afb7b1a1d9279ddeddb3fcade534d741c81
source=(git+${url}#commit=${_commit}
        0001-Do-not-build-shared-libraries.patch)
sha256sums=(SKIP
            1106101935d0343538dd1399c5cf87c9534468b392cfc2ec8627e2e34553b096)
options=(!strip libtool staticlibs)

prepare() {
    if [ -z "${PS5_PAYLOAD_SDK}" ]; then
	export PS5_PAYLOAD_SDK=/opt/ps5-payload-sdk
    fi
    patch -Np1 -d libyuv -i ../0001-Do-not-build-shared-libraries.patch
}

build() {
    source "${PS5_PAYLOAD_SDK}/toolchain/prospero.sh"
    cd libyuv

    ${CMAKE} -DCMAKE_BUILD_TYPE=Release \
	     -B build \
	     -S .
    ${MAKE} -C build yuv
}

package() {
    source "${PS5_PAYLOAD_SDK}/toolchain/prospero.sh"
    cd libyuv

    export DESTDIR="${pkgdir}/${DESTDIR}"
    ${MAKE} -C build install

    ${PS5_CROSS_FIX_ROOT} "${DESTDIR}/${PREFIX}"
}
